{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "mino",
  "rules": {
    "source": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_form"
      }
    },
    "_form": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "nil"
        },
        {
          "type": "SYMBOL",
          "name": "boolean"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "keyword"
        },
        {
          "type": "SYMBOL",
          "name": "symbol"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "character"
        },
        {
          "type": "SYMBOL",
          "name": "list"
        },
        {
          "type": "SYMBOL",
          "name": "vector"
        },
        {
          "type": "SYMBOL",
          "name": "map"
        },
        {
          "type": "SYMBOL",
          "name": "set"
        },
        {
          "type": "SYMBOL",
          "name": "quote"
        },
        {
          "type": "SYMBOL",
          "name": "quasiquote"
        },
        {
          "type": "SYMBOL",
          "name": "unquote_splicing"
        },
        {
          "type": "SYMBOL",
          "name": "unquote"
        },
        {
          "type": "SYMBOL",
          "name": "deref"
        },
        {
          "type": "SYMBOL",
          "name": "shorthand_fn"
        },
        {
          "type": "SYMBOL",
          "name": "discard"
        },
        {
          "type": "SYMBOL",
          "name": "metadata"
        },
        {
          "type": "SYMBOL",
          "name": "var_quote"
        },
        {
          "type": "SYMBOL",
          "name": "reader_conditional"
        },
        {
          "type": "SYMBOL",
          "name": "reader_conditional_splice"
        },
        {
          "type": "SYMBOL",
          "name": "tagged_literal"
        },
        {
          "type": "SYMBOL",
          "name": "special_float"
        }
      ]
    },
    "nil": {
      "type": "STRING",
      "value": "nil"
    },
    "boolean": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "true"
        },
        {
          "type": "STRING",
          "value": "false"
        }
      ]
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "CHOICE",
                      "members": [
                        {
                          "type": "STRING",
                          "value": "+"
                        },
                        {
                          "type": "STRING",
                          "value": "-"
                        }
                      ]
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                },
                {
                  "type": "PATTERN",
                  "value": "0[xX][0-9a-fA-F]+"
                }
              ]
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "CHOICE",
                      "members": [
                        {
                          "type": "STRING",
                          "value": "+"
                        },
                        {
                          "type": "STRING",
                          "value": "-"
                        }
                      ]
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                },
                {
                  "type": "PATTERN",
                  "value": "\\d{1,2}r[0-9a-zA-Z]+"
                }
              ]
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "CHOICE",
                      "members": [
                        {
                          "type": "STRING",
                          "value": "+"
                        },
                        {
                          "type": "STRING",
                          "value": "-"
                        }
                      ]
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                },
                {
                  "type": "PATTERN",
                  "value": "\\d+\\/\\d+"
                }
              ]
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "CHOICE",
                      "members": [
                        {
                          "type": "STRING",
                          "value": "+"
                        },
                        {
                          "type": "STRING",
                          "value": "-"
                        }
                      ]
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                },
                {
                  "type": "PATTERN",
                  "value": "\\d+(\\.\\d*)?([eE][+-]?\\d+)?[NM]?"
                }
              ]
            }
          ]
        }
      }
    },
    "keyword": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": ":"
          },
          {
            "type": "PATTERN",
            "value": "[^\\s,;()\\[\\]{}'\"`~^]+"
          }
        ]
      }
    },
    "symbol": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\s,;()\\[\\]{}'\"`~@\\d:#^\\\\][^\\s,;()\\[\\]{}'\"`~@^]*"
      }
    },
    "string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "escape_sequence"
              },
              {
                "type": "PATTERN",
                "value": "[^\"\\\\]+"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "escape_sequence": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\\\\."
      }
    },
    "character": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\\"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "space"
              },
              {
                "type": "STRING",
                "value": "newline"
              },
              {
                "type": "STRING",
                "value": "tab"
              },
              {
                "type": "STRING",
                "value": "return"
              },
              {
                "type": "STRING",
                "value": "backspace"
              },
              {
                "type": "PATTERN",
                "value": "."
              }
            ]
          }
        ]
      }
    },
    "list": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_form"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "vector": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_form"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "map": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_form"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "set": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_form"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "quote": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "'"
        },
        {
          "type": "SYMBOL",
          "name": "_form"
        }
      ]
    },
    "quasiquote": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "`"
        },
        {
          "type": "SYMBOL",
          "name": "_form"
        }
      ]
    },
    "unquote_splicing": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "~@"
        },
        {
          "type": "SYMBOL",
          "name": "_form"
        }
      ]
    },
    "unquote": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "~"
        },
        {
          "type": "SYMBOL",
          "name": "_form"
        }
      ]
    },
    "deref": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "@"
        },
        {
          "type": "SYMBOL",
          "name": "_form"
        }
      ]
    },
    "shorthand_fn": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_form"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "discard": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#_"
        },
        {
          "type": "SYMBOL",
          "name": "_form"
        }
      ]
    },
    "metadata": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "^"
        },
        {
          "type": "SYMBOL",
          "name": "_form"
        },
        {
          "type": "SYMBOL",
          "name": "_form"
        }
      ]
    },
    "var_quote": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#'"
        },
        {
          "type": "SYMBOL",
          "name": "_form"
        }
      ]
    },
    "reader_conditional": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#?"
        },
        {
          "type": "SYMBOL",
          "name": "list"
        }
      ]
    },
    "reader_conditional_splice": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#?@"
        },
        {
          "type": "SYMBOL",
          "name": "list"
        }
      ]
    },
    "tagged_literal": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "SYMBOL",
          "name": "symbol"
        },
        {
          "type": "SYMBOL",
          "name": "_form"
        }
      ]
    },
    "special_float": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "##Inf"
          },
          {
            "type": "STRING",
            "value": "##-Inf"
          },
          {
            "type": "STRING",
            "value": "##NaN"
          }
        ]
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": ";"
          },
          {
            "type": "PATTERN",
            "value": ".*"
          }
        ]
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[\\s,]"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}