    "authors": [
      {
        "name": "Leif Eric Fredheim"
      }
    ],
    "links": {
      "repository": "https://github.com/leifericf/tree-sitter-mino"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
